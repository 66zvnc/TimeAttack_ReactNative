{
  "expo": {
    "name": "TimeAttack",
    "slug": "timeattack",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1a1a1a"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.yourname.timeattackgps",
      "icon": "./assets/icon.png",
      "infoPlist": {
        "NSLocationAlwaysAndWhenInUseUsageDescription": "TimeAttack needs your location to track time attack runs in the background.",
        "NSLocationWhenInUseUsageDescription": "TimeAttack needs your location to track time attack runs.",
        "UIBackgroundModes": [
          "location"
        ]
      }
    },
    "android": {
      "package": "com.yourname.timeattackgps",
      "icon": "./assets/icon.png",
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#1a1a1a"
      },
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ],
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyBFAjtpcBdMuXkledgxsnoIX7IW4kAs_hg"
        }
      }
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "TimeAttack needs your location to track time attack runs in the background.",
          "locationAlwaysPermission": "TimeAttack needs your location to track time attack runs in the background.",
          "locationWhenInUsePermission": "TimeAttack needs your location to track time attack runs.",
          "isIosBackgroundLocationEnabled": true,
          "isAndroidBackgroundLocationEnabled": true
        }
      ],
      [
        "expo-font",
        {
          "fonts": [
            "./fonts/Inter/static/Inter_24pt-Regular.ttf",
            "./fonts/Inter/static/Inter_24pt-Medium.ttf",
            "./fonts/Inter/static/Inter_24pt-SemiBold.ttf",
            "./fonts/Inter/static/Inter_24pt-Bold.ttf"
          ]
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "6778e786-b869-4b90-950b-f20c94d82895"
      }
    }
  }
}
